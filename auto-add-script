#!/usr/bin/env python
"""\
Script to automatically add metadata to all .ipynb files in the /nj67-papers/original/*/ directory

Please run this file from the root directory of the project
"""
from pathlib import Path
from notebook_parser import add_notebook_metadata

sample_dir = Path() / 'nj67-papers' / 'original'
for dir in sample_dir.iterdir():
    if not dir.is_dir(): 
        continue
    for file in dir.iterdir():
        if file.is_file() and file.suffix == '.ipynb':
            print("Writing metadata to", file.absolute())
            add_notebook_metadata(file, file)
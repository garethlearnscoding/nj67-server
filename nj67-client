class Env:
    UPLOAD_PATH: Path = Path('ans_booklet')
    UPLOAD_URI: str = 'http://127.0.0.1:5000/upload'
    DOWNLOAD_URI: str = 'http://127.0.0.1:5000/download'
    VIEW_URI: str = 'http://127.0.0.1:5000/view'
    DOWNLOAD_PATH: str | None = None
    CONFIG_DIR = get_config_dir()
    COOKIE_FILE = CONFIG_DIR / "cookies-pickled"
    VERBOSE = False

    def __init__(self, *, args: argparse.Namespace|None=None):
        if args is not None:
            if args.command in ('download', 'd'):
                self.DOWNLOAD_PATH = args.path or self.DOWNLOAD_PATH
            elif args.command in ('upload', 'u'):
                self.UPLOAD_PATH = Path(args.path) if args.path else self.UPLOAD_PATH
            self.VERBOSE = args.verbose
            if self.VERBOSE: print("Verbose: Will print more")

def init_parser():
    parent = argparse.ArgumentParser(add_help=False)
    parent.add_argument('-p', '--path')
    parent.add_argument('-v', '--verbose', action='store_true')
    parser = argparse.ArgumentParser(description="NJ67 Client", add_help=False)
    subparsers = parser.add_subparsers(dest='command')
    subparsers.add_parser('help', aliases=['h', '-h', '--help'])
    download_parser = subparsers.add_parser('download', aliases=['d'], parents=[parent])
    upload_parser = subparsers.add_parser('upload', aliases=['u'], parents=[parent])
    view_parser = subparsers.add_parser('view', aliases=['v'], parents=[parent])
    return parser

try:
    args = init_parser().parse_args()
except SystemExit:
    # When invalid argument given
    sys.exit(__doc__)
env = Env(args=args)

class Cookie_env:
    def __init__(self):
        self.s = requests.Session()
        if env.COOKIE_FILE.exists():
            if env.VERBOSE: print(f"Found cookie file at {env.COOKIE_FILE.absolute()}")
            with open(env.COOKIE_FILE, 'rb') as f:
                self.s.cookies.update(pickle.load(f))
        elif env.VERBOSE: print(f"Did not find cookie file at {env.COOKIE_FILE.absolute()}, creating new session")
    def __enter__(self):
        return self.s
    def __exit__(self, type, value, traceback):
        with open(env.COOKIE_FILE, 'wb') as f:
            if env.VERBOSE: print(f"Saving cookies at {env.COOKIE_FILE.absolute()}")
            pickle.dump(self.s.cookies, f)

def download():
    with Cookie_env() as sess:
        try:
            if env.VERBOSE: print(f"Connecting to {env.DOWNLOAD_URI}")
            r = sess.get(env.DOWNLOAD_URI, params={})
        except requests.exceptions.ConnectionError:
            sys.exit("Error with connection, check that you are connected to the internet.")
    if r.status_code == 200:
        if env.VERBOSE: print(f"Got zip file, headers are \n{'\n'.join((f"\t{k}: {v}" for k, v in r.headers.items()))}")
        with zipfile.ZipFile(BytesIO(r.content), 'r') as zip_ref:
            zip_ref.extractall(path=env.DOWNLOAD_PATH)
    else:
        sys.exit(f"Error occured when downloading file (got status code {r.status_code})")

def upload():
    try:
        temp_ans = tempfile.NamedTemporaryFile(prefix=env.UPLOAD_PATH.stem, suffix='.zip', delete=False)
        if env.VERBOSE: print(f"Making temp zip file at {temp_ans.name}")
        shutil.make_archive(temp_ans.name[:-4], 'zip', env.UPLOAD_PATH)
    except FileNotFoundError as e:
        sys.exit(f"No directory '{e.filename}' found")
    with Cookie_env() as sess:
        if env.VERBOSE: print(f"Connecting to {env.UPLOAD_URI}")
        r = sess.post(env.UPLOAD_URI, files={'file': ('ans_booklet.zip', temp_ans, 'application/zip')})
        if env.VERBOSE: print(f"Success, response headers are: \n{'\n'.join((f"\t{k}: {v}" for k, v in r.headers.items()))}" + f"\n\tcontent: '{r.text}'")
        else: print("response:", r.text)

def view():
    with Cookie_env() as sess:
        if env.VERBOSE: print(f"Connecting to {env.DOWNLOAD_URI}")
        res = sess.get(env.VIEW_URI, params={'list': 'True'})
    if res.status_code == 200:
        file_list = json.loads(res.content) or ["[-No files found-]"]
        print('\n\t'.join(["Uploaded files: "] + file_list))

        
if args.command in ('help', 'h', None):
    print(__doc__)
    sys.exit(0)
elif args.command in ('download', 'd'):
    download()
elif args.command in ('upload', 'u'):
    upload()
elif args.command in ('view', 'v'):
    view()

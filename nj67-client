#!/usr/bin/env python
"""\
Usage: nj67-client <command> [<arguments>...]

<Commands>
  h, help      : Print this help message
  d, download  : Download files
  u, upload    : Upload files

<Arguments>
 -p, --path <path> : Specify the path in which to upload/download the file
 -v, --verbose     : Verbose output (will print more)
"""

VERSION = "v0.0.1"

import argparse
import json
import pickle
import requests
import shutil
import sys
import tempfile
import zipfile


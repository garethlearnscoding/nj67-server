#!/usr/bin/env python
"""\
nj67-client v0.0.2
Usage: nj67-client <command> [<arguments>...]

<Commands>
  h, help      : Print this help message
  d, download  : Download files
  u, upload    : Upload files
  v, view      : View uploaded files
     update    : Update this program

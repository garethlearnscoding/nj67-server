except ModuleNotFoundError:
    # source: https://github.com/python/cpython/blob/main/Lib/_colorize.py
    class ANSIColors:
        RESET = "\x1b[0m"
        BLACK = "\x1b[30m"
        BLUE = "\x1b[34m"
        CYAN = "\x1b[36m"
        GREEN = "\x1b[32m"
        GREY = "\x1b[90m"
        MAGENTA = "\x1b[35m"
        RED = "\x1b[31m"
        WHITE = "\x1b[37m"  # more like LIGHT GRAY
        YELLOW = "\x1b[33m"

        BOLD = "\x1b[1m"
        BOLD_BLACK = "\x1b[1;30m"  # DARK GRAY
        BOLD_BLUE = "\x1b[1;34m"
        BOLD_CYAN = "\x1b[1;36m"
        BOLD_GREEN = "\x1b[1;32m"
        BOLD_MAGENTA = "\x1b[1;35m"
        BOLD_RED = "\x1b[1;31m"
        BOLD_WHITE = "\x1b[1;37m"  # actual WHITE
        BOLD_YELLOW = "\x1b[1;33m"

DEBUG = True

logging.basicConfig(format="%(message)s", level=logging.INFO if DEBUG else None)
logging.captureWarnings(True)
warnings.formatwarning = lambda message, *args, **kwargs: f'{ANSIColors.RED}{ANSIColors.BOLD}WARNING: {message}{ANSIColors.RESET}'

app = Flask(__name__)
app.secret_key = os.environ.get("FLASK_SECRET_KEY", '')
if not app.secret_key:
    warnings.warn("Please set FLASK_SECRET_KEY environment variable so that user_id will not change with every server restart")
    app.secret_key = uuid.uuid4().hex
else:
    logging.info("Flask secret key found in env variable FLASK_SECRET_KEY")

cwd = Path(app.root_path)
output_dir = cwd / 'output'
output_dir.mkdir(exist_ok=True)

@app.before_request
def create_if_not_exists_session():
    if 'user_id' not in session:
        session['user_id'] = str(uuid.uuid4())

@app.route('/')
def index():
    return send_from_directory(cwd / 'static', 'index.html')

@app.route('/favicon.ico')
def favicon():
    return send_from_directory(cwd / 'static', 'favicon.ico', mimetype='image/vnd.microsoft.icon')

@app.route('/upload', methods=['POST'])
def get_ans():
    out_dir = output_dir / session['user_id'] / datetime.now().strftime('%Y-%m-%d_%H-%M-%S')
    out_dir.mkdir(parents=True, exist_ok=True)
    with ZipFile(request.files['file'].stream) as zip_ref:
        zip_ref.extractall(out_dir)
    contents = tuple(out_dir.iterdir())
    if len(contents) == 1 and contents[0].is_dir():
        try:
            for child in contents[0].iterdir():
                child.rename(out_dir / child.name)
            contents[0].rmdir()
        except OSError: 
            return "Error: invalid zip file", 500
    
    # Process uploaded .ipynb files
    code_string = ""
    for f in out_dir.iterdir():
        if f.is_file() and f.suffix == '.ipynb':
            cells = proc_file(f)
            for cell in cells:
                if isinstance(cell['source'], list):
                    code_string += '\n'.join(cell['source']) + '\n'
                else:
                    code_string += cell['source'] + '\n'
    
    # Get paper and task from form data
    paper = request.form.get('paper', '2CZ_NJC_24')
    task = request.form.get('task', 'TASK1')
    test_pattern = f"test_{paper}_{task}.py"
    
    # Run Docker test runner
    result = subprocess.run(
        ["docker", "run", "--rm", "test_env", "python", "docker_test_runner.py", code_string, test_pattern],
        capture_output=True, text=True, timeout=10
    )
    if result.returncode == 0:
        return jsonify(json.loads(result.stdout)), 200
    else:
        return jsonify({
            "success": False,
            "error": result.stderr
        }), 500

@app.route('/download', methods=['GET'])
def papers_please():
    if request.args:
